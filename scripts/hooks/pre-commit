#!/bin/sh
# Pre-commit hook: scan staged files for secrets using gitleaks.
# Install via: npm run install-hooks

if ! command -v gitleaks > /dev/null 2>&1; then
  echo "⚠️  gitleaks not found — skipping secret scan."
  echo "   Install it: https://github.com/gitleaks/gitleaks#installing"
  echo "   Or via brew: brew install gitleaks"
  exit 0
fi

gitleaks protect --staged --config .gitleaks.toml --redact -v

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ gitleaks found potential secrets in staged files."
  echo "   Review the output above, remove the secret, and re-stage."
  echo "   If it is a false positive, add it to .gitleaks.toml allowlist."
  exit 1
fi
