# Gmail Smart Forward — config template
# Copy this to .env and fill in your values
# Run `npm run build-env` after editing, then `clasp push`

FORWARD_TO_EMAIL=receipts@your-target.com

# Fill these in after running discoverSuppliers()
ALLOWED_SENDERS=
ALLOWED_DOMAINS=

EXCLUDED_SENDERS=
EXCLUDED_DOMAINS=

DISCOVERY_DAYS=365
BACKFILL_AFTER_DATE=2025/04/10

DRY_RUN=true
MAX_EMAILS_PER_RUN=50
ENABLE_LIVE_FORWARDING=false

CANDIDATE_LABEL=revolut-candidate
FORWARDED_LABEL=revolut-forwarded
REJECTED_LABEL=revolut-rejected
DISCOVERED_LABEL=revolut-discovered
