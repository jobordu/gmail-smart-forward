# Gmail Smart Forward — config template
# Copy this to .env and fill in your values.
# After editing, run: npm run push
# Then in the Apps Script editor: setup.gs → bootstrapProperties → Run

# ── Required ─────────────────────────────────────────────────────────────────

# Where invoices are forwarded TO (e.g. accounting inbox, bookkeeper, Revolut)
FORWARD_TO_EMAIL=receipts@your-target.com

# ── Allowlist (fill in after running discoverSuppliers) ───────────────────────

# Comma-separated sender emails to trust
ALLOWED_SENDERS=

# Comma-separated sender domains to trust (use sparingly — trusts all addresses at that domain)
ALLOWED_DOMAINS=

# ── Denylist (optional) ───────────────────────────────────────────────────────

EXCLUDED_SENDERS=
EXCLUDED_DOMAINS=

# ── Attachments ───────────────────────────────────────────────────────────────

# Comma-separated file extensions (without dot) that count as valid invoice attachments
ATTACHMENT_EXTENSIONS=pdf

# ── Backfill window ───────────────────────────────────────────────────────────

# How many days back to scan for suppliers and invoices
DISCOVERY_DAYS=365

# Backfill start date (YYYY/MM/DD).
# Leave blank to auto-compute as today - DISCOVERY_DAYS each time you run npm run push.
# Set explicitly to pin a fixed historical window regardless of when you deploy.
BACKFILL_AFTER_DATE=

# ── Safety ────────────────────────────────────────────────────────────────────

# Keep true until you have reviewed the dry-run output. Then set to false.
DRY_RUN=true

# Max threads processed per execution (Google Workspace: safe up to ~300)
MAX_EMAILS_PER_RUN=200

# Set to true only after the backfill looks correct
ENABLE_LIVE_FORWARDING=false

# ── LLM invoice classification (optional, multimodal — email + PDF) ──────────

# Set to true to enable LLM-based invoice verification (runs after allowlist check)
ENABLE_LLM_CLASSIFICATION=false

# API key for your inference provider
LLM_API_KEY=

# Base URL for any OpenAI-compatible provider:
#   Together AI  → https://api.together.xyz/v1
#   AkashML      → https://chatapi.akash.network/api/v1
#   OpenAI       → https://api.openai.com/v1
LLM_BASE_URL=https://api.together.xyz/v1

# Model to use — must support multimodal (vision) input for PDF analysis.
# Together AI options (serverless):
#   Qwen/Qwen3-VL-8B-Instruct          — dedicated vision model, cheapest ($0.18/$0.68 per M tokens)
#   google/gemma-4-31b-it              — Gemma 4 multimodal, good quality ($0.20/$0.50)
#   moonshotai/Kimi-K2.5               — strong document understanding ($0.50/$2.80)
# OpenAI:
#   gpt-4o                             — best PDF comprehension, most expensive
LLM_MODEL=google/gemma-4-31b-it

# Minimum confidence score (0.0–1.0) to forward. Emails below this threshold
# are rejected with reason 'llm-not-invoice'. Default: 0.7
LLM_CONFIDENCE_THRESHOLD=0.7

# ── Gmail labels (defaults are fine, change only if you need custom names) ────

CANDIDATE_LABEL=gmail-smart-forward/candidate
FORWARDED_LABEL=gmail-smart-forward/forwarded
REJECTED_LABEL=gmail-smart-forward/rejected
DISCOVERED_LABEL=gmail-smart-forward/discovered
