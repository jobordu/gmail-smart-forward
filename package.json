{
  "name": "gmail-smart-forward",
  "version": "1.7.0",
  "description": "Forward receipts/invoices from approved suppliers to a target email address",
  "scripts": {
    "build-env": "node scripts/build-env.js",
    "push": "npm run build-env && clasp push",
    "pull": "clasp pull",
    "deploy": "npm run build-env && clasp push && clasp deploy",
    "open": "clasp open",
    "logs": "clasp logs",
    "install-hooks": "sh scripts/install-hooks.sh",
    "secrets": "gitleaks detect --config .gitleaks.toml --redact -v",
    "secrets:staged": "gitleaks protect --staged --config .gitleaks.toml --redact -v",
    "test": "jest --coverage --testPathIgnorePatterns=e2e-llm --forceExit",
    "test:e2e": "jest test/e2e-llm.test.js --verbose --forceExit",
    "test:watch": "jest --watch --testPathIgnorePatterns=e2e-llm",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "validate": "node scripts/validate-env.js",
    "generate-transform": "node test/transform/generate.js"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.8",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "jest": "^30.3.0"
  }
}
